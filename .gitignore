# ============================================================
# Scooby — .gitignore
# ============================================================

# ---------- Environment ----------
.env
.env.local
.env.*.local

# ---------- Local scratch / eval output ----------
.firecrawl/
test_generations/

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# ---------- Node.js ----------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Remotion ----------
remotion/out/

# ---------- Misc ----------
*.log
tmp/
